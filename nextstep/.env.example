# NextStep AI Environment Configuration
# Copy this file to .env and fill in the values

# PostgreSQL Database (run: docker compose up -d)
DATABASE_URL=postgres://postgres:nextstep_dev_2026@localhost:5432/nextstep_ai

# Django Settings
DJANGO_SECRET_KEY=   # Generate: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (comma-separated, include your production domain in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Frontend URL — used in verification/reset email links
FRONTEND_URL=http://localhost:5173

# Redis (run: docker compose up -d)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# AI Service — Groq (free tier: https://console.groq.com)
GROQ_API_KEY=

# Job Data Sources
JSEARCH_API_KEY=       # RapidAPI JSearch — free tier: 200 req/month
ADZUNA_APP_ID=         # https://developer.adzuna.com
ADZUNA_APP_KEY=

# Email / SMTP
# Leave blank to use console backend (prints links to terminal — fine for development)
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → create app password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=NextStep AI <noreply@yourdomain.com>
